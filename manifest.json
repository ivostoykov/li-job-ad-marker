{
  "manifest_version": 3,
  "name": "LinkedIn Job Ad Marker",
  "version": "0.0.3",
  "description": "Marks viewed, applied, and blacklisted company job ads on LinkedIn.",
  "permissions": [
    "storage",
    "contextMenus"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": [
        "src/js/db.js",
        "src/js/blacklist.js",
        "src/content.js"
      ],
      "css": ["src/css/marker.css"],
      "run_at": "document_idle"
    }
  ]
}
