{
  "manifest_version": 3,
  "name": "LinkedIn Job Ad Marker",
  "version": "1.1.56",
  "description": "Marks viewed, applied, and blacklisted company job ads on LinkedIn.",
  "permissions": ["storage", "contextMenus", "tabs"],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "options_page": "src/options.html",
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": [
        "src/js/utils.js",
        "src/js/settings.js",
        "src/js/db.js",
        "src/js/blacklist.js",
        "src/js/log.js",
        "src/content.js"
      ],
      "css": ["src/css/marker.css"],
      "run_at": "document_idle"
    }
  ]
}
